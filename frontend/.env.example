# Los puertos y el realm vienen del .env raiz del repo.
# El frontend (admin/operador) corre en la misma maquina, por eso usa localhost
# y NO depende de LAN_IP. Lanzalo con ./run-local.sh o con `npm run dev`.
VITE_IDENTITY_API_BASE_URL=http://${KEYCLOAK_HOST:-localhost}:${IDENTITY_PORT:-5000}
VITE_TRIVIA_API_BASE_URL=http://${KEYCLOAK_HOST:-localhost}:${TRIVIA_PORT:-5015}
VITE_BDT_API_BASE_URL=http://${KEYCLOAK_HOST:-localhost}:${BDT_PORT:-5016}
VITE_KEYCLOAK_URL=http://${KEYCLOAK_HOST:-localhost}:${KEYCLOAK_PORT:-8080}
VITE_KEYCLOAK_REALM=${KEYCLOAK_REALM:-UMBRAL-UCAB}
VITE_KEYCLOAK_CLIENT_ID=umbral-web
