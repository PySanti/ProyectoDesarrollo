# La IP, los puertos y el realm vienen del .env raiz del repo.
#
# NO copies este archivo a .env a mano: el .env real lo GENERA ./run-local.sh
# con valores LITERALES ya resueltos. Expo/Babel construye un modulo virtual
# .env que NO expande ${VAR}; si dejas ${...} en .env se queda con el default
# (localhost) y el telefono no podra abrir Keycloak ("no se pudo cargar la
# pagina"). Lanza siempre el movil con ./run-local.sh.
# No edites la IP aqui: cambiala en <repo>/.env (LAN_IP).
IP=${LAN_IP:-localhost}
REACT_NATIVE_PACKAGER_HOSTNAME=${IP}
EXPO_PUBLIC_KEYCLOAK_URL=http://${IP}:${KEYCLOAK_PORT:-8080}
EXPO_PUBLIC_KEYCLOAK_REALM=${KEYCLOAK_REALM:-UMBRAL-UCAB}
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=umbral-mobile
EXPO_PUBLIC_GATEWAY_BASE_URL=http://${IP}:${GATEWAY_PORT:-5080}
EXPO_PUBLIC_APP_SCHEME=umbral
EXPO_PUBLIC_AUTH_REDIRECT_URI=exp://${IP}:${METRO_PORT:-8081}/--/auth
