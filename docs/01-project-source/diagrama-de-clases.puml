@startuml
title Diagrama de Clases de Diseño - Sistema UMBRAL

left to right direction

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false

hide methods

' ============================================================
' ENUMERACIONES
' ============================================================

enum TipoRol {
  ADMINISTRADOR
  OPERADOR
  PARTICIPANTE
}

enum EstadoUsuario {
  ACTIVO
  INACTIVO
  DESACTIVADO
}

enum EstadoEquipo {
  ACTIVO
  INACTIVO
}

enum ModoJuego {
  TRIVIA
  BUSQUEDA_TESORO
}

enum EstadoSesion {
  PROGRAMADA
  EN_PREPARACION
  ACTIVA
  PAUSADA
  FINALIZADA
  CANCELADA
}

enum EstadoMision {
  BORRADOR
  ACTIVA
  INACTIVA
  ARCHIVADA
}

enum NivelDificultad {
  BAJA
  MEDIA
  ALTA
}

enum EstadoQuiz {
  BORRADOR
  PUBLICADO
  ARCHIVADO
}

enum EstadoEvidencia {
  PENDIENTE
  ACEPTADA
  RECHAZADA
  PENALIZADA
}

enum EstadoPreguntaSesion {
  PENDIENTE
  ACTIVA
  CERRADA
}

enum ResultadoRespuesta {
  PENDIENTE
  CORRECTA
  INCORRECTA
  RECHAZADA
}

enum TipoEventoSesion {
  CAMBIO_ESTADO
  ASOCIACION_EQUIPO
  LIBERACION_PISTA
  ENVIO_EVIDENCIA
  VALIDACION_EVIDENCIA
  ENVIO_RESPUESTA
  CIERRE_PREGUNTA
  PENALIZACION
  CAMBIO_PUNTAJE
  RECONEXION_PARTICIPANTE
}

enum TipoMovimientoPuntaje {
  RESPUESTA_TRIVIA
  EVIDENCIA_VALIDADA
  PENALIZACION
  AJUSTE
}

enum TipoNotificacionInterna {
  EVENTO_SESION
  ACTUALIZACION_RANKING
  ACTUALIZACION_TEMPORIZADOR
  RESULTADO_PREGUNTA
  PISTA_LIBERADA
  EVIDENCIA_VALIDADA
}

' ============================================================
' CAPA DE DOMINIO
' ============================================================

package "Dominio" {

  package "Acceso y usuarios" {

    abstract class Usuario {
      +id: UUID
      +nombre: String
      +correo: String
      +estado: EstadoUsuario
      +fechaCreacion: DateTime
      +ultimoAcceso: DateTime
    }

    class Administrador {
      +codigoAdministrador: String
    }

    class Operador {
      +codigoOperador: String
    }

    class Participante {
      +codigoParticipante: String
      +alias: String
    }

    class Rol {
      +id: UUID
      +nombre: String
      +tipo: TipoRol
      +descripcion: String
    }

    class Permiso {
      +id: UUID
      +codigo: String
      +descripcion: String
      +modulo: String
    }

    class UsuarioRol {
      +id: UUID
      +fechaAsignacion: DateTime
      +activo: Boolean
    }
  }

  package "Equipos" {

    class Equipo {
      +id: UUID
      +nombre: String
      +descripcion: String
      +estado: EstadoEquipo
      +fechaRegistro: DateTime
    }

    class EquipoParticipante {
      +id: UUID
      +fechaAsignacion: DateTime
      +activo: Boolean
    }
  }

  package "Sesiones" {

    abstract class Sesion {
      +id: UUID
      +codigoAcceso: String
      +nombre: String
      +estado: EstadoSesion
      +fechaProgramada: DateTime
      +fechaInicio: DateTime
      +fechaFin: DateTime
      +duracionMaximaMinutos: Integer
      +criterioDesempate: String
    }

    class SesionTrivia {
      +modo: ModoJuego = TRIVIA
      +quizId: UUID
      +preguntaActivaId: UUID
    }

    class SesionBusquedaTesoro {
      +modo: ModoJuego = BUSQUEDA_TESORO
      +misionId: UUID
    }

    class SesionEquipo {
      +id: UUID
      +fechaAsociacion: DateTime
      +estadoEnSesion: String
      +progresoActual: Decimal
      +ultimoAcceso: DateTime
    }

    class TemporizadorSesion {
      +id: UUID
      +duracionSegundos: Integer
      +tiempoRestanteSegundos: Integer
      +fechaInicio: DateTime
      +fechaPausa: DateTime
      +activo: Boolean
    }

    class RankingSesion {
      +id: UUID
      +fechaActualizacion: DateTime
      +criterioOrdenamiento: String
    }

    class PosicionRanking {
      +id: UUID
      +posicion: Integer
      +puntajeAcumulado: Integer
      +criterioDesempateValor: String
    }

    class EventoSesion {
      +id: UUID
      +tipo: TipoEventoSesion
      +descripcion: String
      +fechaEvento: DateTime
      +datos: Json
      +responsableId: UUID
    }

    class Penalizacion {
      +id: UUID
      +motivo: String
      +puntosDescontados: Integer
      +fechaAplicacion: DateTime
      +responsableId: UUID
    }

    class MovimientoPuntaje {
      +id: UUID
      +tipo: TipoMovimientoPuntaje
      +puntos: Integer
      +descripcion: String
      +fechaMovimiento: DateTime
      +origenId: UUID
    }

    class PuntajeEquipoSesion {
      +id: UUID
      +puntajeTotal: Integer
      +fechaActualizacion: DateTime
    }
  }

  package "Busqueda del Tesoro" {

    class Mision {
      +id: UUID
      +nombre: String
      +descripcion: String
      +nivelDificultad: NivelDificultad
      +estado: EstadoMision
      +tiempoMaximoMinutos: Integer
      +fechaCreacion: DateTime
      +fechaActualizacion: DateTime
    }

    class Etapa {
      +id: UUID
      +nombre: String
      +descripcion: String
      +orden: Integer
      +puntajeBase: Integer
    }

    class Nodo {
      +id: UUID
      +nombre: String
      +descripcion: String
      +orden: Integer
    }

    class Objetivo {
      +id: UUID
      +descripcion: String
      +puntaje: Integer
      +orden: Integer
      +requiereEvidencia: Boolean
    }

    class Pista {
      +id: UUID
      +contenido: String
      +orden: Integer
      +penalizacionPorUso: Integer
    }

    class PistaLiberada {
      +id: UUID
      +fechaLiberacion: DateTime
      +liberadaPorId: UUID
      +duplicada: Boolean
    }

    class Evidencia {
      +id: UUID
      +descripcion: String
      +urlArchivo: String
      +fechaEnvio: DateTime
      +estado: EstadoEvidencia
      +observacionValidacion: String
    }

    class ValidacionEvidencia {
      +id: UUID
      +resultado: EstadoEvidencia
      +comentario: String
      +fechaValidacion: DateTime
      +responsableId: UUID
    }

    class ProgresoMisionEquipo {
      +id: UUID
      +porcentajeAvance: Decimal
      +etapaActualId: UUID
      +objetivoActualId: UUID
      +fechaActualizacion: DateTime
    }
  }

  package "Trivia" {

    class Quiz {
      +id: UUID
      +titulo: String
      +descripcion: String
      +estado: EstadoQuiz
      +fechaCreacion: DateTime
      +fechaPublicacion: DateTime
    }

    class Pregunta {
      +id: UUID
      +enunciado: String
      +orden: Integer
      +puntaje: Integer
      +tiempoLimiteSegundos: Integer
    }

    class OpcionRespuesta {
      +id: UUID
      +texto: String
      +orden: Integer
      +esCorrecta: Boolean
    }

    class PreguntaSesion {
      +id: UUID
      +estado: EstadoPreguntaSesion
      +fechaInicio: DateTime
      +fechaCierre: DateTime
      +tiempoLimiteSegundos: Integer
    }

    class RespuestaTrivia {
      +id: UUID
      +fechaEnvio: DateTime
      +resultado: ResultadoRespuesta
      +puntosObtenidos: Integer
      +rechazoMotivo: String
    }

    class ResultadoPreguntaEquipo {
      +id: UUID
      +correcta: Boolean
      +puntosObtenidos: Integer
      +fechaResultado: DateTime
    }
  }

  package "Servicios de Dominio" {

    class ValidadorTransicionSesion <<Domain Service>>
    class ValidadorAccesoParticipante <<Domain Service>>
    class ValidadorModoJuego <<Domain Service>>
    class CalculadorPuntaje <<Domain Service>>
    class CalculadorRanking <<Domain Service>>
    class ValidadorMision <<Domain Service>>
    class ValidadorQuiz <<Domain Service>>
    class ValidadorRespuestaTrivia <<Domain Service>>
    class ValidadorEvidencia <<Domain Service>>
    class ValidadorLiberacionPista <<Domain Service>>
  }
}

' ============================================================
' CAPA DE APLICACION - CQRS / MEDIATR
' ============================================================

package "Aplicacion - CQRS / MediatR" {

  package "Comandos" {

    class CrearSesionTriviaCommand <<Command>> {
      +quizId: UUID
      +operadorId: UUID
      +nombreSesion: String
      +fechaProgramada: DateTime
    }

    class CrearSesionBusquedaTesoroCommand <<Command>> {
      +misionId: UUID
      +operadorId: UUID
      +nombreSesion: String
      +fechaProgramada: DateTime
    }

    class CambiarEstadoSesionCommand <<Command>> {
      +sesionId: UUID
      +nuevoEstado: EstadoSesion
      +operadorId: UUID
    }

    class AsociarEquipoSesionCommand <<Command>> {
      +sesionId: UUID
      +equipoId: UUID
      +operadorId: UUID
    }

    class LiberarPistaCommand <<Command>> {
      +sesionId: UUID
      +equipoId: UUID
      +pistaId: UUID
      +operadorId: UUID
    }

    class EnviarEvidenciaCommand <<Command>> {
      +sesionId: UUID
      +equipoId: UUID
      +participanteId: UUID
      +objetivoId: UUID
      +descripcion: String
      +urlArchivo: String
    }

    class ValidarEvidenciaCommand <<Command>> {
      +evidenciaId: UUID
      +operadorId: UUID
      +resultado: EstadoEvidencia
      +comentario: String
    }

    class ActivarPreguntaTriviaCommand <<Command>> {
      +sesionTriviaId: UUID
      +preguntaId: UUID
      +operadorId: UUID
    }

    class CerrarPreguntaTriviaCommand <<Command>> {
      +preguntaSesionId: UUID
      +operadorId: UUID
    }

    class EnviarRespuestaTriviaCommand <<Command>> {
      +preguntaSesionId: UUID
      +equipoId: UUID
      +participanteId: UUID
      +opcionRespuestaId: UUID
    }

    class AplicarPenalizacionCommand <<Command>> {
      +sesionId: UUID
      +equipoId: UUID
      +operadorId: UUID
      +motivo: String
      +puntosDescontados: Integer
    }
  }

  package "Consultas" {

    class ConsultarSesionQuery <<Query>> {
      +sesionId: UUID
    }

    class ConsultarRankingQuery <<Query>> {
      +sesionId: UUID
    }

    class ConsultarTableroParticipanteQuery <<Query>> {
      +participanteId: UUID
      +sesionId: UUID
    }

    class ConsultarHistorialSesionQuery <<Query>> {
      +sesionId: UUID
    }

    class ConsultarEvidenciasPendientesQuery <<Query>> {
      +sesionId: UUID
    }

    class ConsultarEstadoRespuestasTriviaQuery <<Query>> {
      +preguntaSesionId: UUID
    }
  }

  package "Handlers" {

    class CrearSesionTriviaHandler <<Handler>>
    class CrearSesionBusquedaTesoroHandler <<Handler>>
    class CambiarEstadoSesionHandler <<Handler>>
    class AsociarEquipoSesionHandler <<Handler>>
    class LiberarPistaHandler <<Handler>>
    class EnviarEvidenciaHandler <<Handler>>
    class ValidarEvidenciaHandler <<Handler>>
    class ActivarPreguntaTriviaHandler <<Handler>>
    class CerrarPreguntaTriviaHandler <<Handler>>
    class EnviarRespuestaTriviaHandler <<Handler>>
    class AplicarPenalizacionHandler <<Handler>>

    class ConsultarSesionHandler <<Query Handler>>
    class ConsultarRankingHandler <<Query Handler>>
    class ConsultarTableroParticipanteHandler <<Query Handler>>
    class ConsultarHistorialSesionHandler <<Query Handler>>
    class ConsultarEvidenciasPendientesHandler <<Query Handler>>
    class ConsultarEstadoRespuestasTriviaHandler <<Query Handler>>
  }

  package "DTO / Read Models" {

    class SesionReadModel <<Read Model>> {
      +id: UUID
      +nombre: String
      +modo: ModoJuego
      +estado: EstadoSesion
      +fechaInicio: DateTime
      +fechaFin: DateTime
    }

    class EquipoSesionReadModel <<Read Model>> {
      +equipoId: UUID
      +nombreEquipo: String
      +puntaje: Integer
      +progreso: Decimal
      +estado: String
    }

    class RankingReadModel <<Read Model>> {
      +sesionId: UUID
      +fechaActualizacion: DateTime
    }

    class PosicionRankingReadModel <<Read Model>> {
      +posicion: Integer
      +equipoId: UUID
      +nombreEquipo: String
      +puntaje: Integer
    }

    class TableroParticipanteReadModel <<Read Model>> {
      +sesionId: UUID
      +equipoId: UUID
      +estadoSesion: EstadoSesion
      +puntaje: Integer
      +progreso: Decimal
      +tiempoRestanteSegundos: Integer
    }

    class EventoSesionReadModel <<Read Model>> {
      +id: UUID
      +tipo: TipoEventoSesion
      +descripcion: String
      +fechaEvento: DateTime
    }
  }

  package "Puertos de Aplicacion" {

    interface IUnitOfWork <<Port>>
    interface IEventBus <<Port>>
    interface IRealtimeNotifier <<Port>>
    interface IClock <<Port>>
    interface ILoggerService <<Port>>
  }
}

' ============================================================
' PUERTOS DEL DOMINIO / REPOSITORIOS
' ============================================================

package "Puertos de Dominio - Repositorios" {

  interface IUsuarioRepository <<Repository Port>>
  interface IRolRepository <<Repository Port>>
  interface IEquipoRepository <<Repository Port>>
  interface ISesionRepository <<Repository Port>>
  interface IMisionRepository <<Repository Port>>
  interface IQuizRepository <<Repository Port>>
  interface IEvidenciaRepository <<Repository Port>>
  interface IRespuestaTriviaRepository <<Repository Port>>
  interface IEventoSesionRepository <<Repository Port>>
  interface IPuntajeRepository <<Repository Port>>
  interface IRankingRepository <<Repository Port>>
}

' ============================================================
' CAPA DE INFRAESTRUCTURA
' ============================================================

package "Infraestructura" {

  package "Persistencia - PostgreSQL / EF Core" {

    class UmbralDbContext <<EF Core DbContext>> {
      +usuarios: DbSet<Usuario>
      +roles: DbSet<Rol>
      +equipos: DbSet<Equipo>
      +sesiones: DbSet<Sesion>
      +misiones: DbSet<Mision>
      +quizzes: DbSet<Quiz>
      +evidencias: DbSet<Evidencia>
      +respuestasTrivia: DbSet<RespuestaTrivia>
      +eventosSesion: DbSet<EventoSesion>
      +puntajes: DbSet<PuntajeEquipoSesion>
    }

    class UsuarioRepository <<EF Core Repository>>
    class RolRepository <<EF Core Repository>>
    class EquipoRepository <<EF Core Repository>>
    class SesionRepository <<EF Core Repository>>
    class MisionRepository <<EF Core Repository>>
    class QuizRepository <<EF Core Repository>>
    class EvidenciaRepository <<EF Core Repository>>
    class RespuestaTriviaRepository <<EF Core Repository>>
    class EventoSesionRepository <<EF Core Repository>>
    class PuntajeRepository <<EF Core Repository>>
    class RankingRepository <<EF Core Repository>>

    class UnitOfWork <<EF Core Unit of Work>>
  }

  package "Tiempo Real - WebSockets" {

    class SesionHub <<WebSocket Hub>> {
      +hubName: String
    }

    class RealtimeNotifier <<Adapter>>
  }

  package "Mensajeria - RabbitMQ" {

    class RabbitMqEventBus <<Adapter>> {
      +exchangeName: String
      +queueName: String
    }

    class EventoSesionMessage <<Message>> {
      +eventoId: UUID
      +sesionId: UUID
      +tipo: TipoEventoSesion
      +payload: Json
      +fechaPublicacion: DateTime
    }

    class PuntajeRecalculadoMessage <<Message>> {
      +sesionId: UUID
      +equipoId: UUID
      +puntajeTotal: Integer
      +fechaPublicacion: DateTime
    }

    class NotificacionInternaMessage <<Message>> {
      +tipo: TipoNotificacionInterna
      +sesionId: UUID
      +destinatarioId: UUID
      +payload: Json
    }
  }

  package "Servicios Transversales" {

    class ClockService <<Adapter>>
    class LoggerService <<Adapter>>
    class ExceptionHandlerMiddleware <<Middleware>>
    class ValidationBehavior <<MediatR Pipeline>>
    class LoggingBehavior <<MediatR Pipeline>>
  }
}

' ============================================================
' CAPA DE PRESENTACION / API
' ============================================================

package "Presentacion - API Web .NET" {

  class AuthController <<REST Controller>>
  class UsuariosController <<REST Controller>>
  class EquiposController <<REST Controller>>
  class SesionesController <<REST Controller>>
  class MisionesController <<REST Controller>>
  class QuizzesController <<REST Controller>>
  class EvidenciasController <<REST Controller>>
  class TriviaController <<REST Controller>>
  class RankingController <<REST Controller>>
  class HistorialController <<REST Controller>>

  class ReactWebClient <<Frontend React>> {
    +urlBaseApi: String
    +usaWebSockets: Boolean
    +responsive: Boolean
  }

  class PanelAdministrador <<React View>>
  class PanelOperador <<React View>>
  class PanelParticipante <<React View>>
}

' ============================================================
' RELACIONES - HERENCIA DE USUARIOS
' ============================================================

Usuario <|-- Administrador
Usuario <|-- Operador
Usuario <|-- Participante

Usuario "1" -- "0..*" UsuarioRol
Rol "1" -- "0..*" UsuarioRol
Rol "1" -- "0..*" Permiso

' ============================================================
' RELACIONES - EQUIPOS Y PARTICIPANTES
' ============================================================

Equipo "1" -- "0..*" EquipoParticipante
Participante "1" -- "0..*" EquipoParticipante

' ============================================================
' RELACIONES - SESIONES
' ============================================================

Sesion <|-- SesionTrivia
Sesion <|-- SesionBusquedaTesoro

Operador "1" -- "0..*" Sesion : crea / administra >
Sesion "1" -- "0..*" SesionEquipo
Equipo "1" -- "0..*" SesionEquipo

Sesion "1" *-- "0..1" TemporizadorSesion
Sesion "1" *-- "0..1" RankingSesion
RankingSesion "1" *-- "0..*" PosicionRanking
PosicionRanking "1" --> "1" Equipo

Sesion "1" *-- "0..*" EventoSesion
Sesion "1" *-- "0..*" Penalizacion
Sesion "1" *-- "0..*" MovimientoPuntaje
Sesion "1" *-- "0..*" PuntajeEquipoSesion

Equipo "1" -- "0..*" PuntajeEquipoSesion
Equipo "1" -- "0..*" MovimientoPuntaje
Equipo "1" -- "0..*" Penalizacion

Penalizacion "1" --> "1" Operador : responsable >
MovimientoPuntaje "0..*" --> "0..1" Penalizacion : origen >
MovimientoPuntaje "0..*" --> "0..1" RespuestaTrivia : origen >
MovimientoPuntaje "0..*" --> "0..1" Evidencia : origen >

' ============================================================
' RELACIONES - BUSQUEDA DEL TESORO
' ============================================================

SesionBusquedaTesoro "1" --> "1" Mision
Mision "1" *-- "1..*" Etapa
Etapa "1" *-- "0..*" Nodo
Etapa "1" *-- "0..*" Objetivo
Nodo "1" *-- "0..*" Objetivo
Objetivo "1" *-- "0..*" Pista

SesionBusquedaTesoro "1" *-- "0..*" PistaLiberada
Pista "1" -- "0..*" PistaLiberada
Equipo "1" -- "0..*" PistaLiberada
Operador "1" -- "0..*" PistaLiberada : libera >

SesionBusquedaTesoro "1" *-- "0..*" Evidencia
Participante "1" -- "0..*" Evidencia : envia >
Equipo "1" -- "0..*" Evidencia
Objetivo "1" -- "0..*" Evidencia

Evidencia "1" -- "0..1" ValidacionEvidencia
Operador "1" -- "0..*" ValidacionEvidencia : valida >

SesionBusquedaTesoro "1" *-- "0..*" ProgresoMisionEquipo
Equipo "1" -- "0..*" ProgresoMisionEquipo
Etapa "0..1" -- "0..*" ProgresoMisionEquipo
Objetivo "0..1" -- "0..*" ProgresoMisionEquipo

' ============================================================
' RELACIONES - TRIVIA
' ============================================================

SesionTrivia "1" --> "1" Quiz
Quiz "1" *-- "1..*" Pregunta
Pregunta "1" *-- "2..*" OpcionRespuesta

SesionTrivia "1" *-- "0..*" PreguntaSesion
Pregunta "1" -- "0..*" PreguntaSesion

PreguntaSesion "1" *-- "0..*" RespuestaTrivia
Equipo "1" -- "0..*" RespuestaTrivia
Participante "1" -- "0..*" RespuestaTrivia
OpcionRespuesta "1" -- "0..*" RespuestaTrivia

PreguntaSesion "1" *-- "0..*" ResultadoPreguntaEquipo
Equipo "1" -- "0..*" ResultadoPreguntaEquipo
RespuestaTrivia "0..1" -- "0..1" ResultadoPreguntaEquipo

' ============================================================
' RELACIONES - SERVICIOS DE DOMINIO
' ============================================================

ValidadorTransicionSesion ..> Sesion
ValidadorAccesoParticipante ..> Participante
ValidadorAccesoParticipante ..> Equipo
ValidadorAccesoParticipante ..> Sesion
ValidadorModoJuego ..> Sesion
CalculadorPuntaje ..> MovimientoPuntaje
CalculadorPuntaje ..> PuntajeEquipoSesion
CalculadorRanking ..> RankingSesion
CalculadorRanking ..> PosicionRanking
ValidadorMision ..> Mision
ValidadorQuiz ..> Quiz
ValidadorRespuestaTrivia ..> RespuestaTrivia
ValidadorRespuestaTrivia ..> PreguntaSesion
ValidadorEvidencia ..> Evidencia
ValidadorEvidencia ..> SesionBusquedaTesoro
ValidadorLiberacionPista ..> PistaLiberada
ValidadorLiberacionPista ..> Pista

' ============================================================
' RELACIONES - COMANDOS Y HANDLERS
' ============================================================

CrearSesionTriviaCommand --> CrearSesionTriviaHandler
CrearSesionBusquedaTesoroCommand --> CrearSesionBusquedaTesoroHandler
CambiarEstadoSesionCommand --> CambiarEstadoSesionHandler
AsociarEquipoSesionCommand --> AsociarEquipoSesionHandler
LiberarPistaCommand --> LiberarPistaHandler
EnviarEvidenciaCommand --> EnviarEvidenciaHandler
ValidarEvidenciaCommand --> ValidarEvidenciaHandler
ActivarPreguntaTriviaCommand --> ActivarPreguntaTriviaHandler
CerrarPreguntaTriviaCommand --> CerrarPreguntaTriviaHandler
EnviarRespuestaTriviaCommand --> EnviarRespuestaTriviaHandler
AplicarPenalizacionCommand --> AplicarPenalizacionHandler

ConsultarSesionQuery --> ConsultarSesionHandler
ConsultarRankingQuery --> ConsultarRankingHandler
ConsultarTableroParticipanteQuery --> ConsultarTableroParticipanteHandler
ConsultarHistorialSesionQuery --> ConsultarHistorialSesionHandler
ConsultarEvidenciasPendientesQuery --> ConsultarEvidenciasPendientesHandler
ConsultarEstadoRespuestasTriviaQuery --> ConsultarEstadoRespuestasTriviaHandler

' ============================================================
' RELACIONES - HANDLERS CON DOMINIO Y PUERTOS
' ============================================================

CrearSesionTriviaHandler ..> ISesionRepository
CrearSesionTriviaHandler ..> IQuizRepository
CrearSesionTriviaHandler ..> ValidadorQuiz
CrearSesionTriviaHandler ..> IEventBus
CrearSesionTriviaHandler ..> IUnitOfWork

CrearSesionBusquedaTesoroHandler ..> ISesionRepository
CrearSesionBusquedaTesoroHandler ..> IMisionRepository
CrearSesionBusquedaTesoroHandler ..> ValidadorMision
CrearSesionBusquedaTesoroHandler ..> IEventBus
CrearSesionBusquedaTesoroHandler ..> IUnitOfWork

CambiarEstadoSesionHandler ..> ISesionRepository
CambiarEstadoSesionHandler ..> ValidadorTransicionSesion
CambiarEstadoSesionHandler ..> IRealtimeNotifier
CambiarEstadoSesionHandler ..> IEventBus
