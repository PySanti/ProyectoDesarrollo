# ============================================================================
# UMBRAL - Variables de entorno GLOBALES (plantilla)
# ----------------------------------------------------------------------------
# Copia este archivo a `.env` (raiz del repo) y ajusta los valores.
# Es la fuente unica de verdad: los .env de cada microservicio y cliente
# referencian estos valores con ${VAR} y se cargan automaticamente desde los
# scripts run-local.* de cada componente.
# ============================================================================

# IP de LAN de esta maquina. Cambiala cuando uses el movil en un telefono
# fisico: debe ser la IP que el telefono puede alcanzar en la misma red Wi-Fi.
LAN_IP=<IP-LAN>

# --- Keycloak ---
KEYCLOAK_HOST=localhost
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=UMBRAL-UCAB

# --- Base de datos (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=55432
DB_USER=umbral
DB_PASSWORD=16102005

# --- Puertos de los microservicios ---
IDENTITY_PORT=5000
GATEWAY_PORT=5080

# --- Metro bundler (Expo) ---
METRO_PORT=8081

# --- Correo real (Gmail app password) — identity lo usa via docker compose ---
# Genera una "contraseña de aplicación" en tu cuenta Google (requiere 2FA).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_USERNAME=<tu-correo@gmail.com>
SMTP_PASSWORD=<app-password-16-chars>
SMTP_FROM_ADDRESS=<tu-correo@gmail.com>
SMTP_FROM_NAME=UMBRAL

# --- Client secret del cliente confidencial identity-service en Keycloak ---
KEYCLOAK_CLIENT_SECRET=<secret-del-cliente-identity-service>
