# Valores globales (LAN_IP, puertos, Keycloak, BD) vienen del .env raiz del repo.
# Editalos alli, no aqui. Aqui solo van los valores propios de este servicio.
ASPNETCORE_ENVIRONMENT='Development'
ASPNETCORE_URLS="http://localhost:${IDENTITY_PORT:-5000}"
ConnectionStrings__IdentityDatabase="Host=${DB_HOST:-localhost};Port=${DB_PORT:-55432};Database=umbral_identity;Username=${DB_USER:-umbral};Password=${DB_PASSWORD:-16102005}"
KEYCLOAK_BASE_URL="http://${KEYCLOAK_HOST:-localhost}:${KEYCLOAK_PORT:-8080}"
KEYCLOAK_REALM="${KEYCLOAK_REALM:-UMBRAL-UCAB}"
KEYCLOAK_CLIENT_ID='identity-service'
KEYCLOAK_VALID_AUDIENCES='identity-service,umbral-web,account'
KEYCLOAK_VALID_ISSUERS="http://${KEYCLOAK_HOST:-localhost}:${KEYCLOAK_PORT:-8080}/realms/${KEYCLOAK_REALM:-UMBRAL-UCAB},http://${LAN_IP:-localhost}:${KEYCLOAK_PORT:-8080}/realms/${KEYCLOAK_REALM:-UMBRAL-UCAB}"
KEYCLOAK_CLIENT_SECRET='umbral-identity-secret'

# SMTP para el correo de bienvenida (contraseña temporal). Ejemplo con Gmail + app password.
# Crear el app password en https://myaccount.google.com/apppasswords (requiere 2FA).
SMTP_HOST='smtp.gmail.com'
SMTP_PORT='587'
SMTP_USE_STARTTLS='true'
SMTP_USERNAME='tu-cuenta@gmail.com'
SMTP_PASSWORD='tu-app-password-de-16-caracteres'
SMTP_FROM_ADDRESS='tu-cuenta@gmail.com'
SMTP_FROM_NAME='UMBRAL'
