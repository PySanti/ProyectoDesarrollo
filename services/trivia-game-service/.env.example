# Valores globales (puertos, BD) vienen del .env raiz del repo.
# Editalos alli, no aqui. Aqui solo van los valores propios de este servicio.
ASPNETCORE_ENVIRONMENT='Development'
ASPNETCORE_URLS="http://0.0.0.0:${TRIVIA_PORT:-5015}"
ConnectionStrings__TriviaGameDb="Host=${DB_HOST:-localhost};Port=${DB_PORT:-55432};Database=umbral_trivia_game;Username=${DB_USER:-umbral};Password=${DB_PASSWORD:-16102005}"
